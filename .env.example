# Weather Chain - Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# WALLET CONFIGURATION
# ============================================

# Private key for server wallet (TESTING ONLY - use secure storage in production)
# Generate a secure key: openssl rand -hex 32
SERVER_PRIVATE_KEY=your_private_key_here

# Wallet storage URL (for storing funding basket outputs)
WALLET_STORAGE_URL=https://store-us-1.bsvb.tech

# BSV Network: main or test
BSV_NETWORK=test

# ============================================
# TEMPEST API CONFIGURATION
# ============================================

# Your WeatherFlow Tempest API token
# Get it from: https://tempestwx.com/settings/tokens
TEMPEST_API_KEY=your_tempest_api_key_here

# Streaming mode: websocket, polling, or auto
# - websocket: Use real-time WebSocket (recommended)
# - polling: Use REST API polling (fallback)
# - auto: Try WebSocket, fall back to polling on failure
STREAMING_MODE=auto

# Polling interval (seconds) - only used in polling mode
POLL_RATE=300

# ============================================
# MONGODB CONFIGURATION
# ============================================

# MongoDB connection URI
# For local development: mongodb://localhost:27017/weather-chain
# For production: mongodb://user:password@host:port/weather-chain?authSource=admin
MONGO_URI=mongodb://localhost:27017/weather-chain

# ============================================
# FUNDING BASKET CONFIGURATION
# ============================================

# Amount (in satoshis) per funding output
FUNDING_OUTPUT_AMOUNT=1000

# Minimum number of outputs to keep in funding basket
FUNDING_BASKET_MIN=200

# Number of outputs to create when refilling basket
FUNDING_BATCH_SIZE=1000

# ============================================
# TRANSACTION CONFIGURATION
# ============================================

# Number of weather data outputs per transaction
WEATHER_OUTPUTS_PER_TX=100

# ============================================
# SERVICE CONFIGURATION
# ============================================

# Funding basket monitoring interval (seconds)
MONITOR_INTERVAL=60

# Queue processor interval (seconds)
PROCESSOR_INTERVAL=3

# ============================================
# OPTIONAL: ADVANCED CONFIGURATION
# ============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable/disable Prometheus metrics
ENABLE_METRICS=false

# Metrics port (if enabled)
METRICS_PORT=9090

# WebSocket reconnection settings
WS_MAX_RECONNECT_ATTEMPTS=10
WS_INITIAL_RECONNECT_DELAY=5000
